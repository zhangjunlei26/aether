{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aether",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#actors"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.aether",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.aether",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control",
          "match": "\\b(if|else|for|while|switch|case|default|break|continue|return|match|receive|send|spawn_actor|spawn|self|let|var|state|struct|actor|func|int|float|bool|string|void|actor_ref|message)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.tag.aether",
          "match": "\\b(int|float|bool|string|void|actor_ref|message)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aether",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aether",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.aether",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "constant.language.boolean.aether",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.aether",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%|==|!=|<|<=|>|>=|&&|\\|\\||!|=|=>)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "constant.numeric",
          "match": "\\bmain\\s*(?=\\()"
        },
        {
          "name": "keyword.control",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "keyword.control",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "actors": {
      "patterns": [
        {
          "name": "meta.actor.aether",
          "begin": "\\b(actor)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "end": "\\{",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "keyword.control"
            }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.aether",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.aether"
}

