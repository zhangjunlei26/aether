// runtime.aeth
// Core runtime built–in functions for Aether.

module Runtime;

import System;

export func builtin_print(text: string): void {
    // Assuming stdout is fd 1.
    System.write(1, text);
}

export func builtin_read_file(path: string): string {
    return System.readFile(path);
}

export func builtin_spawn(task: func()): void {
    System.spawnThread(task);
}
