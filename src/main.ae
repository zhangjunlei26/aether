import Runtime;

main() {
    print("Hello from the Aether runtime!\n");
    int x = 5;
    print("x is %d\n", x);
    if(x==5) {
        spawn(func () {
            print("Hello from a spawned thread!\n");
        });
    } else {
        print("x is not 5\n");
    }
    print("Back in the main thread.\n");
}
