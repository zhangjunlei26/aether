// Benchmark 2: Actor creation/destruction speed

actor Simple {
    state x = 0;
    
    receive(msg) {
        x = x + 1;
    }
}

main() {
    print("Creating 10000 actors...\n");
    
    i = 0;
    while (i < 10000) {
        a = spawn(Simple());
        send(a, 1);
        i = i + 1;
    }
    
    print("Done\n");
}
