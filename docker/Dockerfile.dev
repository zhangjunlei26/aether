# Aether Development Environment
# Full-featured environment with all tools for development and testing
FROM gcc:13-bookworm

LABEL maintainer="Aether Development Team"
LABEL description="Aether Development Environment with full toolchain"
LABEL version="0.4.0"

# Install comprehensive development tools
RUN apt-get update && apt-get install -y \
    # Build essentials
    make \
    cmake \
    ninja-build \
    ccache \
    # Version control
    git \
    # Debugging and profiling
    gdb \
    valgrind \
    strace \
    # Performance tools
    perf-tools-unstable \
    linux-perf \
    # Python for scripts
    python3 \
    python3-pip \
    # Utilities
    vim \
    nano \
    curl \
    wget \
    htop \
    tree \
    # Network tools for testing
    netcat-openbsd \
    telnet \
    && rm -rf /var/lib/apt/lists/*

# Install ccache and configure
RUN mkdir -p /root/.ccache && \
    echo "max_size = 5.0G" > /root/.ccache/ccache.conf

# Set working directory
WORKDIR /aether

# Configure environment
ENV CC=gcc
ENV CXX=g++
ENV CFLAGS="-O2 -g"
ENV PATH="/usr/lib/ccache:${PATH}"

# Display versions
RUN gcc --version && \
    make --version && \
    python3 --version

# Default command: bash shell
CMD ["/bin/bash"]
