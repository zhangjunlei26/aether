[package]
name = "my-aether-project"
version = "0.1.0"
authors = ["Your Name <email@example.com>"]
license = "MIT"
description = "An example Aether project"
repository = "https://github.com/user/my-aether-project"
readme = "README.md"
keywords = ["example", "actors", "concurrent"]

[dependencies]
# Add dependencies with: ae add host/user/repo[@version]
# github.com/user/mylib = "v1.0.0"
# gitlab.com/user/utils = "latest"

[dev-dependencies]
# Development-only dependencies
# aether-test = "0.2"

[build]
target = "native"           # "native" (default) or "wasm" (WebAssembly via Emscripten)
optimizations = "aggressive"
debug-symbols = false

[features]
default = []

[[bin]]
name = "my-project"
path = "src/main.ae"

[scripts]
test = "apkg test"
run = "apkg run"

