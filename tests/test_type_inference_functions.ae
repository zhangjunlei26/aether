// Test: Type inference in functions
// Python-style: clean syntax, types inferred from usage

// Function with inferred parameter and return types
add(a, b) {
    return a + b;  // Parameters and return type inferred from usage
}

multiply(x, y) {
    return x * y;
}

main() {
    result1 = add(10, 20);      // result1 inferred: int
    result2 = multiply(5, 6);   // result2 inferred: int
    
    print(result1);
    print(result2);
}

