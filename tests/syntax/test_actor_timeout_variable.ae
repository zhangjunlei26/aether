// Test: actor timeout with variable expression (not just literal)

message Ping { }

actor Waiter {
    state _count = 0

    receive {
        Ping -> {
            _count = _count + 1
        }
    } after 50 + 50 -> {
        println("PASS: timeout with expression (50+50=100ms)")
    }
}

main() {
    _w = spawn(Waiter())
    wait_for_idle()
}
