// Test std.io module operations
// Covers: write_file, read_file, append_file, file_exists, delete_file, getenv

import std.io
import std.string

main() {
    print("=== I/O Operations Tests ===\n\n")

    tmpfile = "aether_test_io_tmp.txt"

    // Test 1: file_exists on non-existent file
    print("Test 1: file_exists (non-existent)\n")
    if io.file_exists(tmpfile) == 0 {
        print("  PASS: file does not exist yet\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: write_file
    print("\nTest 2: write_file\n")
    result = io.write_file(tmpfile, "hello aether")
    if result == 1 {
        print("  PASS: write_file returned 1\n")
    } else {
        print("  FAIL: returned ")
        print(result)
        print("\n")
        exit(1)
    }

    // Test 3: file_exists after write
    print("\nTest 3: file_exists (after write)\n")
    if io.file_exists(tmpfile) == 1 {
        print("  PASS: file exists\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 4: read_file and verify content
    print("\nTest 4: read_file\n")
    content = io.read_file(tmpfile)
    if content != 0 {
        cstr = string.to_cstr(content)
        if cstr == "hello aether" {
            print("  PASS: read back 'hello aether'\n")
        } else {
            print("  FAIL: content mismatch\n")
            exit(1)
        }
        string.release(content)
    } else {
        print("  FAIL: read_file returned null\n")
        exit(1)
    }

    // Test 5: append_file
    print("\nTest 5: append_file\n")
    io.append_file(tmpfile, "!")
    content2 = io.read_file(tmpfile)
    if content2 != 0 {
        if string.length(content2) == 13 {
            print("  PASS: length after append = 13\n")
        } else {
            print("  FAIL: length = ")
            print(string.length(content2))
            print("\n")
            exit(1)
        }
        string.release(content2)
    } else {
        print("  FAIL: read_file returned null\n")
        exit(1)
    }

    // Test 6: delete_file
    print("\nTest 6: delete_file\n")
    io.delete_file(tmpfile)
    if io.file_exists(tmpfile) == 0 {
        print("  PASS: file deleted\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 7: getenv — PATH exists on all platforms
    print("\nTest 7: getenv\n")
    path_val = io.getenv("PATH")
    if path_val != 0 {
        if string.length(path_val) > 0 {
            print("  PASS: PATH is set, length > 0\n")
        } else {
            print("  FAIL: PATH empty\n")
            exit(1)
        }
    } else {
        print("  FAIL: PATH not set\n")
        exit(1)
    }

    // Test 8: getenv for non-existent variable
    print("\nTest 8: getenv (non-existent)\n")
    nope = io.getenv("AETHER_NONEXISTENT_VAR_XYZ_12345")
    if nope == 0 {
        print("  PASS: non-existent var returns null\n")
    } else {
        print("  PASS: non-existent var returned something (platform-specific)\n")
    }

    // Test 9: console output functions
    print("\nTest 9: io.print / io.print_line / io.print_int\n")
    io.print("  ")
    io.print_int(42)
    io.print_line("")
    io.print_line("  PASS: console output works")

    print("\n=== All I/O Operations Tests Passed ===\n")
}
