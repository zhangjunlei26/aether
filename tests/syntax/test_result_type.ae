// Test: result types — Go-style multiple return values

// Function returning (value, error)
divide(a: int, b: int) -> {
    if b == 0 {
        return 0, "division by zero"
    }
    return a / b, ""
}

// Function returning int pair
swap(a: int, b: int) -> {
    return b, a
}

// Chained error propagation
checked_divide(input: int, divisor: int) -> {
    if input < 0 {
        return 0, "input must be non-negative"
    }
    result, err = divide(input, divisor)
    if err != "" {
        return 0, err
    }
    return result, ""
}

main() {
    // Basic destructuring — Go style: check error, bail, then continue
    result, err = divide(10, 2)
    if err != "" {
        println("FAIL: unexpected error: ${err}")
        exit(1)
    }
    if result != 5 {
        println("FAIL: expected 5, got ${result}")
        exit(1)
    }
    println("PASS: 10/2 = 5")

    // Error case
    _, err2 = divide(10, 0)
    if err2 == "" {
        println("FAIL: expected error for 10/0")
        exit(1)
    }
    println("PASS: division by zero caught: ${err2}")

    // Discard error with _
    val, _ = divide(42, 7)
    if val != 6 {
        println("FAIL: expected 6, got ${val}")
        exit(1)
    }
    println("PASS: discard works, 42/7 = ${val}")

    // Swap (non-error tuple)
    x, y = swap(1, 2)
    if x != 2 {
        println("FAIL: swap x")
        exit(1)
    }
    if y != 1 {
        println("FAIL: swap y")
        exit(1)
    }
    println("PASS: swap(1,2) = (${x}, ${y})")

    // Chained error propagation
    v1, e1 = checked_divide(100, 5)
    if e1 != "" {
        println("FAIL: unexpected chain error")
        exit(1)
    }
    println("PASS: chain 100/5 = ${v1}")

    _, e2 = checked_divide(10, 0)
    if e2 == "" {
        println("FAIL: expected chain error")
        exit(1)
    }
    println("PASS: chain error propagated: ${e2}")

    _, e3 = checked_divide(0 - 1, 5)
    if e3 == "" {
        println("FAIL: expected validation error")
        exit(1)
    }
    println("PASS: chain validation: ${e3}")

    // Double discard
    _, _ = divide(1, 1)
    println("PASS: double discard")

    println("All result type tests passed!")
}
