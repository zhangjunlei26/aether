// Test: Message chain across 4 actors (A -> B -> C -> D)
// Verifies: cooperative scheduler correctly processes messages
// that are sent as side-effects of receiving other messages.
// Works in both threaded and cooperative modes.

message Forward { value: int }
message Done { total: int }

actor StageA {
    state next_ref = 0;

    receive {
        Forward(value) -> {
            // Double the value and forward
            next_ref ! Forward { value: value * 2 };
        }
    }
}

actor StageB {
    state next_ref = 0;

    receive {
        Forward(value) -> {
            // Add 10 and forward
            next_ref ! Forward { value: value + 10 };
        }
    }
}

actor StageC {
    state next_ref = 0;

    receive {
        Forward(value) -> {
            // Multiply by 3 and forward
            next_ref ! Forward { value: value * 3 };
        }
    }
}

actor Collector {
    state result = 0;

    receive {
        Forward(value) -> {
            result = value;
        }
        Done(total) -> {
            // total is unused, just triggers the report
            println("Collector result: ${result}");
            // Input 5 -> StageA: 5*2=10 -> StageB: 10+10=20 -> StageC: 20*3=60
            if result == 60 {
                println("  PASS: chain computed (5*2+10)*3 = 60");
            } else {
                println("  FAIL: expected 60, got ${result}");
                exit(1);
            }
        }
    }
}

main() {
    println("=== Cooperative Chain Test ===");
    println("");

    collector = spawn(Collector());
    c = spawn(StageC());
    b = spawn(StageB());
    a = spawn(StageA());

    // Wire the chain: A -> B -> C -> Collector
    a.next_ref = b;
    b.next_ref = c;
    c.next_ref = collector;

    // Send initial value into the chain
    a ! Forward { value: 5 };

    // Wait for chain to complete
    wait_for_idle();

    // Now trigger the report
    collector ! Done { total: 0 };
    wait_for_idle();

    println("");
    println("Chain test passed!");
}
