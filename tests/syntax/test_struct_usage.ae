// Test struct definition, construction, and field access
// Covers: struct decl, constructor syntax, field read, expressions with fields

struct Point {
    x,
    y
}

struct Rect {
    x,
    y,
    w,
    h
}

main() {
    print("=== Struct Usage Tests ===\n\n")

    // Test 1: Basic construction and field access
    print("Test 1: Construct and read fields\n")
    p = Point { x: 10, y: 20 }
    if p.x == 10 {
        print("  PASS: p.x = 10\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if p.y == 20 {
        print("  PASS: p.y = 20\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: Struct with more fields
    print("\nTest 2: Multi-field struct\n")
    r = Rect { x: 0, y: 0, w: 100, h: 50 }
    a = r.w * r.h
    if a == 5000 {
        print("  PASS: area = 5000\n")
    } else {
        print("  FAIL: area = ")
        print(a)
        print("\n")
        exit(1)
    }

    // Test 3: Using struct fields in expressions
    print("\nTest 3: Fields in expressions\n")
    p2 = Point { x: 3, y: 4 }
    dx = p2.x - p.x
    dy = p2.y - p.y
    dist_sq = dx * dx + dy * dy
    // (3-10)^2 + (4-20)^2 = 49 + 256 = 305
    if dist_sq == 305 {
        print("  PASS: dist_sq = 305\n")
    } else {
        print("  FAIL: dist_sq = ")
        print(dist_sq)
        print("\n")
        exit(1)
    }

    // Test 4: Multiple structs of same type
    print("\nTest 4: Multiple instances\n")
    a1 = Point { x: 1, y: 2 }
    a2 = Point { x: 3, y: 4 }
    sum_x = a1.x + a2.x
    sum_y = a1.y + a2.y
    if sum_x == 4 {
        print("  PASS: sum_x = 4\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if sum_y == 6 {
        print("  PASS: sum_y = 6\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 5: Field used in conditional
    print("\nTest 5: Field in conditional\n")
    player = Rect { x: 0, y: 0, w: 100, h: 80 }
    if player.w > player.h {
        print("  PASS: w > h (landscape)\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\n=== All Struct Usage Tests Passed ===\n")
}
