// Test: selective imports - only imported symbols are accessible
import std.math (sqrt, abs_int)

main() {
    // sqrt and abs_int should be available via qualified name
    result = math.sqrt(16.0)
    println("math.sqrt(16) = ${result}")

    neg = math.abs_int(0 - 5)
    println("math.abs_int(-5) = ${neg}")

    println("Selective import test passed!")
}
