// Test: escape sequences — hex, octal, and print_char builtin
// Covers: \xNN hex, \NNN octal, escapes in interpolated strings, print_char()

main() {
    println("=== Escape Sequence Tests ===")

    // Test 1: Hex escape — \x41 = 'A' (65)
    print("Test 1 hex: ")
    println("\x41\x42\x43")

    // Test 2: Octal escape — \101 = 'A' (65)
    print("Test 2 octal: ")
    println("\101\102\103")

    // Test 3: Hex escape for control chars — \x09 = tab
    print("Test 3 hex tab: ")
    println("A\x09B")

    // Test 4: Octal escape for NUL — \0 still works (backward compat)
    print("Test 4 nul compat: ")
    println("OK")

    // Test 5: Hex escape in interpolated string
    x = 42
    print("Test 5 interp hex: ")
    println("\x48ello ${x}")

    // Test 6: Octal escape in interpolated string
    y = 99
    print("Test 6 interp octal: ")
    println("\110i ${y}")

    // Test 7: Mixed escapes in one string
    print("Test 7 mixed:\n")
    print("\x41\n\x42\n")

    // Test 8: print_char builtin — emit 'A' (65) and newline (10)
    print("Test 8 print_char: ")
    print_char(65)
    print_char(66)
    print_char(67)
    print_char(10)

    // Test 9: print_char with ESC (27) for ANSI — just test it doesn't crash
    print("Test 9 ESC: ")
    print_char(27)
    print("[0m")
    println("OK")

    // Test 10: Uppercase hex digits
    print("Test 10 upper hex: ")
    println("\x4F\x4B")

    println("\n=== All Escape Tests Done ===")
}
