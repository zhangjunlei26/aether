// Test: Platform-independent operations work on all configurations
// Verifies: console I/O, arithmetic, string interpolation, clock_ns
// all work regardless of filesystem/networking availability.
// Exercises code paths that must never break on any platform.

extern puts(s: string) -> int

main() {
    println("=== Stub Behavior Test ===");
    println("");

    // Test 1: Console I/O
    println("Test 1: Console I/O");
    print("  print: ");
    println("OK");

    // Test 2: Arithmetic
    println("Test 2: Arithmetic");
    x = 42;
    y = x * 2 + 1;
    if y == 85 {
        println("  PASS: 42*2+1 = 85");
    } else {
        println("  FAIL: wrong result");
        exit(1);
    }

    // Test 3: String interpolation
    println("Test 3: String interpolation");
    name = "Aether";
    println("  Hello ${name}!");

    // Test 4: clock_ns monotonicity
    println("Test 4: clock_ns");
    t1 = clock_ns();
    t2 = clock_ns();
    if t2 >= t1 {
        println("  PASS: clock_ns is monotonic");
    } else {
        println("  FAIL: clock_ns went backwards");
        exit(1);
    }

    // Test 5: Integer edge cases
    println("Test 5: Integer edge cases");
    zero = 0;
    neg = 0 - 1;
    big = 1000000;
    if zero == 0 {
        println("  PASS: zero");
    } else {
        exit(1);
    }
    if neg < 0 {
        println("  PASS: negative");
    } else {
        exit(1);
    }
    if big > 999999 {
        println("  PASS: large int");
    } else {
        exit(1);
    }

    // Test 6: String operations (always available, no import needed)
    println("Test 6: Multiple println");
    println("  line 1");
    println("  line 2");
    println("  line 3");
    println("  PASS: multiple prints");

    println("");
    println("All stub tests passed!");
}
