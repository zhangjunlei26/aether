// Test: unreachable code warnings
// This file should compile and run, but produce no unreachable warnings
// (all code paths are reachable here)

safe_add(a: int, b: int) -> a + b

main() {
    result = safe_add(1, 2)
    println("result = ${result}")

    // This is reachable — no return before it
    x = 10
    if x > 5 {
        println("big")
    } else {
        println("small")
    }
    // Code after non-exhaustive if (no return in branches) is reachable
    println("Unreachable code test passed!")
}
