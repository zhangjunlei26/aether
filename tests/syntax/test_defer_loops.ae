// Test defer behavior inside loops and nested scopes
// Covers: defer in for loop, defer in while loop, defer in nested blocks

extern puts(s: string) -> int

main() {
    print("=== Defer in Loops Tests ===\n\n")

    // Test 1: defer in for loop (each iteration gets its own defer)
    print("Test 1: defer in for loop\n")
    print("  Expect: iteration outputs then defers in reverse per-iteration\n")
    for i in 0..3 {
        defer puts("  defer fired")
        print("  iteration ")
        print(i)
        print("\n")
    }

    // Test 2: defer outside loop runs after loop completes
    print("\nTest 2: defer before loop\n")
    defer puts("  outer defer (after loop)")
    for i in 0..2 {
        print("  loop ")
        print(i)
        print("\n")
    }
    print("  after loop, before outer defer\n")

    // Test 3: nested scopes with defer
    print("\nTest 3: nested scopes\n")
    print("  entering outer\n")
    defer puts("  defer: outer scope")
    if 1 == 1 {
        print("  entering inner\n")
        defer puts("  defer: inner scope")
        print("  leaving inner\n")
    }
    print("  after inner block\n")

    print("\n=== Defer Loop Tests Done ===\n")
}
