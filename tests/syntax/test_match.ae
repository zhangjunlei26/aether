// Test: match statements and expressions

main() {
    // Match as statement
    x = 2
    match x {
        0 -> println("FAIL: should not match 0")
        1 -> println("FAIL: should not match 1")
        2 -> println("PASS: statement match on 2")
        _ -> println("FAIL: should not hit wildcard")
    }

    // Match as expression (int result)
    code = 404
    val = match code {
        200 -> 0
        404 -> 1
        500 -> 2
        _ -> 3
    }
    if val == 1 {
        println("PASS: expression match int = 1")
    } else {
        println("FAIL: expected 1, got ${val}")
    }

    // Match as expression (string result)
    status = 0
    msg = match status {
        0 -> "ok"
        1 -> "warning"
        _ -> "error"
    }
    println("PASS: expression match string = ${msg}")

    // Wildcard match
    y = 99
    label = match y {
        _ -> "wildcard"
    }
    println("PASS: wildcard = ${label}")

    println("Match tests passed!")
}
