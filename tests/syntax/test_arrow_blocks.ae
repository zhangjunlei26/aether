// Test: multi-statement arrow function bodies

// Single expression arrow (baseline)
twice(x) -> x * 2

// Multi-statement arrow with intermediate variables
sum_squares(a, b) -> {
    sq_a = a * a
    sq_b = b * b
    sq_a + sq_b
}

// Multi-statement arrow with if/return
clamp(x, lo, hi) -> {
    if x < lo {
        return lo
    }
    if x > hi {
        return hi
    }
    x
}

// Multi-statement arrow with loop
sum_to(n) -> {
    total = 0
    for (i = 1; i <= n; i++) {
        total += i
    }
    total
}

// Multi-statement with explicit return
abs_val(x) -> {
    if x < 0 {
        return 0 - x
    }
    return x
}

main() {
    println(twice(5))             // expect: 10
    println(sum_squares(3, 4))    // expect: 25
    println(clamp(15, 0, 10))     // expect: 10
    println(clamp(-5, 0, 10))     // expect: 0
    println(clamp(5, 0, 10))      // expect: 5
    println(sum_to(10))           // expect: 55
    println(abs_val(-7))          // expect: 7
    println(abs_val(3))           // expect: 3
}
