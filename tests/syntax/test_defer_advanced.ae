// Test advanced defer scenarios
// Verifies: LIFO ordering, defer in nested scopes

main() {
    print("=== Advanced Defer Tests ===\n\n")

    // Test 1: Multiple defers execute in LIFO order
    print("Test 1: LIFO order\n")
    print("  Order: ")
    {
        defer print("3 ")
        defer print("2 ")
        defer print("1 ")
    }
    print("\n  PASS\n")

    // Test 2: Nested scope defers
    print("\nTest 2: Nested scopes\n")
    print("  Order: ")
    {
        defer print("outer ")
        {
            defer print("inner ")
        }
    }
    print("\n  PASS\n")

    // Test 3: Defer does not execute if scope not entered
    print("\nTest 3: Conditional defer\n")
    x = 0
    if x > 0 {
        defer print("  should not see this\n")
    }
    print("  PASS (no deferred output above)\n")

    print("\n=== All 3 Defer Tests Passed ===\n")
}
