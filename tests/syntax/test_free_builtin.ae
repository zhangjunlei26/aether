// Test free() builtin with defer — validates memory management pattern
// free() is a language builtin that generates free((void*)ptr) in C output

import std.io
import std.os
import std.string

main() {
    passed = 0

    // Test 1: free with io.getenv (returns malloc'd string)
    home = io.getenv("HOME")
    defer free(home)
    if home != 0 {
        passed = passed + 1
        println("PASS: free with io.getenv")
    } else {
        println("PASS: free with io.getenv (null ok)")
        passed = passed + 1
    }

    // Test 2: free with os.getenv (returns malloc'd string)
    path = os.getenv("PATH")
    defer free(path)
    if path != 0 {
        passed = passed + 1
        println("PASS: free with os.getenv")
    } else {
        println("PASS: free with os.getenv (null ok)")
        passed = passed + 1
    }

    // Test 3: free with os.exec (returns malloc'd string)
    output = os.exec("echo test_free_works")
    defer free(output)
    if output != 0 {
        passed = passed + 1
        println("PASS: free with os.exec")
    } else {
        println("FAIL: os.exec returned null")
    }

    // Test 4: free with string.concat (returns AetherString*)
    s = string.concat("hello", " world")
    defer string.release(s)
    if string.length(s) == 11 {
        passed = passed + 1
        println("PASS: string.release with concat")
    } else {
        println("FAIL: string.concat wrong length")
    }

    // Test 5: free(NULL) is safe (C standard guarantees this)
    missing = os.getenv("AETHER_NONEXISTENT_VAR_12345")
    defer free(missing)
    if missing == 0 {
        passed = passed + 1
        println("PASS: free(NULL) is safe")
    } else {
        println("PASS: free(NULL) test (var unexpectedly set)")
        passed = passed + 1
    }

    println("")
    print("Tests passed: ")
    print(passed)
    println(" / 5")
}
