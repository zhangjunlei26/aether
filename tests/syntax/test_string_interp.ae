// Test: string interpolation
// Tests ${expr} syntax in strings as values (heap-allocated path)

main() {
    // Integer interpolation as value
    x = 42
    msg = "value: ${x}"
    println(msg)

    // String interpolation as value
    name = "world"
    greeting = "hello ${name}"
    println(greeting)

    // Expression interpolation as value
    a = 3
    b = 4
    result = "${a} + ${b} = ${a + b}"
    println(result)
}
