// Test pattern matching with guard clauses (when)
// Covers: function clauses with guards, literal patterns, multi-clause dispatch

// Simple guard: sign detection
sign(n) when n < 0 -> -1
sign(n) when n == 0 -> 0
sign(n) when n > 0 -> 1

// Multiple clauses with literal + guarded fallback
factorial(0) -> 1
factorial(n) when n > 0 -> n * factorial(n - 1)

// Guards with two parameters
max_of(a, b) when a >= b -> a
max_of(a, b) when a < b -> b

// Guards with range checks
classify(x) when x < 0 -> -1
classify(x) when x == 0 -> 0
classify(x) when x <= 10 -> 1
classify(x) when x > 10 -> 2

// Mutual recursion with guards
is_even(0) -> 1
is_even(n) when n > 0 -> is_odd(n - 1)

is_odd(0) -> 0
is_odd(n) when n > 0 -> is_even(n - 1)

main() {
    print("=== Pattern Guard Tests ===\n\n")

    // Test 1: sign function
    print("Test 1: sign guards\n")
    if sign(-5) == -1 {
        print("  PASS: sign(-5) = -1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if sign(0) == 0 {
        print("  PASS: sign(0) = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if sign(42) == 1 {
        print("  PASS: sign(42) = 1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: factorial with literal + guard
    print("\nTest 2: factorial (literal + guard)\n")
    if factorial(5) == 120 {
        print("  PASS: factorial(5) = 120\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if factorial(0) == 1 {
        print("  PASS: factorial(0) = 1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 3: two-parameter guards
    print("\nTest 3: max_of with two params\n")
    if max_of(7, 12) == 12 {
        print("  PASS: max(7,12) = 12\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if max_of(20, 5) == 20 {
        print("  PASS: max(20,5) = 20\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 4: range guards
    print("\nTest 4: classify with range guards\n")
    if classify(-3) == -1 {
        print("  PASS: classify(-3) = -1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if classify(0) == 0 {
        print("  PASS: classify(0) = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if classify(5) == 1 {
        print("  PASS: classify(5) = 1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if classify(99) == 2 {
        print("  PASS: classify(99) = 2\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 5: mutual recursion with guards
    print("\nTest 5: is_even/is_odd mutual recursion\n")
    if is_even(8) == 1 {
        print("  PASS: is_even(8) = 1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if is_even(7) == 0 {
        print("  PASS: is_even(7) = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\n=== All Pattern Guard Tests Passed ===\n")
}
