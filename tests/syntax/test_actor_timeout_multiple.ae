// Test: two actors with different timeouts

message Ping { }

actor FastWaiter {
    state _count = 0

    receive {
        Ping -> { _count = _count + 1 }
    } after 50 -> {
        println("FastWaiter: timeout at 50ms")
    }
}

actor SlowWaiter {
    state _count = 0

    receive {
        Ping -> { _count = _count + 1 }
    } after 150 -> {
        println("SlowWaiter: timeout at 150ms")
    }
}

main() {
    _f = spawn(FastWaiter())
    _s = spawn(SlowWaiter())
    wait_for_idle()
    println("PASS: both timeouts fired")
}
