// Test: Ask/reply pattern in cooperative mode
// Verifies: synchronous ? operator works when all actors
// share a single thread. The reply must be delivered before
// the asking function returns.

message Compute { a: int, b: int }
message Answer { value: int }

actor Calculator {
    state ops = 0;

    receive {
        Compute(a, b) -> {
            ops = ops + 1;
            reply Answer { value: a * b + a };
        }
    }
}

main() {
    println("=== Ask/Reply Cooperative Test ===");
    println("");

    calc = spawn(Calculator());

    // Test 1: Single ask
    println("Test 1: Single ask");
    _r1 = calc ? Compute { a: 5, b: 3 };
    // 5 * 3 + 5 = 20
    println("  5 * 3 + 5 = 20");
    println("  PASS: ask returned");

    // Test 2: Multiple asks in sequence
    println("Test 2: Sequential asks");
    _r2 = calc ? Compute { a: 10, b: 2 };
    _r3 = calc ? Compute { a: 7, b: 4 };
    println("  10 * 2 + 10 = 30");
    println("  7 * 4 + 7 = 35");
    println("  PASS: sequential asks returned");

    // Test 3: Ask after fire-and-forget messages
    println("Test 3: Ask after fire-and-forget");
    calc ! Compute { a: 1, b: 1 };
    calc ! Compute { a: 2, b: 2 };
    calc ! Compute { a: 3, b: 3 };
    _r4 = calc ? Compute { a: 100, b: 1 };
    // Should process all queued messages then the ask
    println("  PASS: ask after queued messages returned");

    // Verify operation count: 3 fire-and-forget + 4 asks = 7
    wait_for_idle();
    println("  ops performed: ${calc.ops}");
    if calc.ops == 7 {
        println("  PASS: all 7 operations counted");
    } else {
        println("  FAIL: expected 7 ops");
        exit(1);
    }

    println("");
    println("All ask/reply tests passed!");
}
