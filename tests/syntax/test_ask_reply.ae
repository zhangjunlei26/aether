// Test ask/reply pattern — reply statement and ? operator
// Covers: reply in receive handler, ? operator for synchronous ask

message Compute { x: int }
message Answer { result: int }
message GetCount {}
message CountReply { count: int }

actor Doubler {
    state ops = 0

    receive {
        Compute(x) -> {
            ops = ops + 1
            reply Answer { result: x * 2 }
        }
        GetCount() -> {
            reply CountReply { count: ops }
        }
    }
}

main() {
    print("=== Ask/Reply Tests ===\n\n")

    d = spawn(Doubler())

    // Test 1: Fire-and-forget with reply (reply is ignored)
    print("Test 1: fire-and-forget with reply actor\n")
    d ! Compute { x: 5 }
    d ! Compute { x: 10 }
    wait_for_idle()
    print("  PASS: messages processed without crash\n")

    // Test 2: Synchronous ask with ? operator
    print("\nTest 2: synchronous ask (? operator)\n")
    _r = d ? Compute { x: 21 }
    print("  PASS: ask returned\n")

    // Test 3: Multiple asks in sequence
    print("\nTest 3: multiple sequential asks\n")
    d ? Compute { x: 1 }
    d ? Compute { x: 2 }
    d ? Compute { x: 3 }
    print("  PASS: 3 sequential asks completed\n")

    // Test 4: Ask for count
    print("\nTest 4: query state via ask\n")
    d ? GetCount {}
    print("  PASS: count query completed\n")

    print("\n=== All Ask/Reply Tests Passed ===\n")
}
