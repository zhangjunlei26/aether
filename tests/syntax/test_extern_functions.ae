// Test extern function declarations and C interop
// Covers: extern with return types, parameter types, calling C stdlib

extern abs(x: int) -> int
extern atoi(s: string) -> int
extern puts(s: string) -> int

main() {
    print("=== Extern Function Tests ===\n\n")

    // Test 1: abs() from C stdlib
    print("Test 1: extern abs()\n")
    if abs(-42) == 42 {
        print("  PASS: abs(-42) = 42\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if abs(10) == 10 {
        print("  PASS: abs(10) = 10\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: atoi() from C stdlib
    print("\nTest 2: extern atoi()\n")
    val = atoi("123")
    if val == 123 {
        print("  PASS: atoi(\"123\") = 123\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    val2 = atoi("-50")
    if val2 == -50 {
        print("  PASS: atoi(\"-50\") = -50\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 3: puts() from C stdlib (returns non-negative on success)
    print("\nTest 3: extern puts()\n")
    result = puts("  PASS: puts() returned successfully")
    if result >= 0 {
        print("  PASS: puts() return value >= 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 4: Using extern result in expression
    print("\nTest 4: extern result in expression\n")
    total = abs(-10) + abs(-20)
    if total == 30 {
        print("  PASS: abs(-10) + abs(-20) = 30\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    print("\n=== All Extern Function Tests Passed ===\n")
}
