// Test: C-style typed function parameters
// Covers: return type prefix, typed params, mixed typed/untyped, all types

// C-style: return_type func_name(type param, ...)
int add(int a, int b) {
    return a + b
}

// Return type with untyped params (type inference)
int square(n) {
    return n * n
}

// No return type, typed params
printer(int x) {
    println("x=${x}")
}

// Float params and return
float multiply(float a, float b) {
    return a * b
}

// String param
string echo(string msg) {
    return msg
}

// Long (int64) params
long big_add(long a, long b) {
    return a + b
}

// Mixed typed and untyped params
int mixed(int a, b) {
    return a + b
}

// Colon-style still works alongside C-style
int colon_style(x: int, y: int) {
    return x + y
}

main() {
    // Test 1: int return + int params
    print("Test 1: ")
    println(add(3, 4))

    // Test 2: int return + untyped params
    print("Test 2: ")
    println(square(5))

    // Test 3: void return + typed param
    print("Test 3: ")
    printer(42)

    // Test 4: float return + float params
    print("Test 4: ")
    println(multiply(2.5, 4.0))

    // Test 5: string return + string param
    print("Test 5: ")
    println(echo("hello"))

    // Test 6: long return + long params
    print("Test 6: ")
    println(big_add(1000000, 2000000))

    // Test 7: mixed typed/untyped
    print("Test 7: ")
    println(mixed(10, 20))

    // Test 8: colon-style still works
    print("Test 8: ")
    println(colon_style(7, 8))

    println("\n=== All Typed Param Tests Done ===")
}
