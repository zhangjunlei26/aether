// Test logical operators
// Verifies: &&, ||, !, combined with comparisons

main() {
    print("=== Logical Operator Tests ===\n\n")

    // Test 1: Basic AND
    print("Test 1: AND operator\n")
    a = true
    b = false
    if !(a && a) { print("  FAIL TT\n"); exit(1) }
    if a && b { print("  FAIL TF\n"); exit(1) }
    if b && a { print("  FAIL FT\n"); exit(1) }
    if b && b { print("  FAIL FF\n"); exit(1) }
    print("  PASS\n")

    // Test 2: Basic OR
    print("\nTest 2: OR operator\n")
    if !(a || a) { print("  FAIL TT\n"); exit(1) }
    if !(a || b) { print("  FAIL TF\n"); exit(1) }
    if !(b || a) { print("  FAIL FT\n"); exit(1) }
    if b || b { print("  FAIL FF\n"); exit(1) }
    print("  PASS\n")

    // Test 3: NOT operator
    print("\nTest 3: NOT operator\n")
    if !a { print("  FAIL !true\n"); exit(1) }
    if !b != true { print("  FAIL !false\n"); exit(1) }
    print("  PASS\n")

    // Test 4: Combined with comparisons
    print("\nTest 4: With comparisons\n")
    x = 5
    if !(x > 3 && x < 10) { print("  FAIL range\n"); exit(1) }
    if x > 10 || x < 0 { print("  FAIL out of range\n"); exit(1) }
    print("  PASS\n")

    // Test 5: Complex combinations
    print("\nTest 5: Complex logic\n")
    p = 3
    q = 7
    r = 10
    if !((p < q) && (q < r)) { print("  FAIL chain\n"); exit(1) }
    if (p > q) || (q > r) { print("  FAIL false chain\n"); exit(1) }
    print("  PASS\n")

    print("\n=== All 5 Logical Tests Passed ===\n")
}
