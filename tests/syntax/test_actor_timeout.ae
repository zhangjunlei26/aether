// Test: actor timeout fires when no messages arrive

message Ping { }

actor Waiter {
    state _count = 0

    receive {
        Ping -> {
            _count = _count + 1
        }
    } after 100 -> {
        println("PASS: timeout fired after 100ms")
    }
}

main() {
    _w = spawn(Waiter())
    // Don't send any messages — timeout should fire
    wait_for_idle()
}
