// Test variable scoping and shadowing behavior
// Covers: block scoping, loop variable scoping, nested scope access

main() {
    print("=== Scope and Shadowing Tests ===\n\n")

    // Test 1: outer variable visible in inner block
    print("Test 1: outer variable in inner block\n")
    x = 10
    if 1 == 1 {
        if x == 10 {
            print("  PASS: x visible in inner block\n")
        } else {
            print("  FAIL\n")
            exit(1)
        }
    }

    // Test 2: variable assigned in inner block persists
    print("\nTest 2: assignment in inner block\n")
    y = 0
    if 1 == 1 {
        y = 42
    }
    if y == 42 {
        print("  PASS: y = 42 after inner assignment\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 3: loop variable scope
    print("\nTest 3: for loop variable\n")
    total = 0
    for i in 0..5 {
        total = total + i
    }
    if total == 10 {
        print("  PASS: sum 0..4 = 10\n")
    } else {
        print("  FAIL: total = ")
        print(total)
        print("\n")
        exit(1)
    }

    // Test 4: separate loops with same variable name
    print("\nTest 4: reuse loop variable name\n")
    sum1 = 0
    for i in 0..3 {
        sum1 = sum1 + i
    }
    sum2 = 0
    for i in 10..13 {
        sum2 = sum2 + i
    }
    if sum1 == 3 {
        print("  PASS: sum1 = 3\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if sum2 == 33 {
        print("  PASS: sum2 = 33\n")
    } else {
        print("  FAIL: sum2 = ")
        print(sum2)
        print("\n")
        exit(1)
    }

    // Test 5: nested blocks both modifying outer variable
    print("\nTest 5: nested blocks modify outer\n")
    val = 1
    if 1 == 1 {
        val = val + 10
        if 1 == 1 {
            val = val + 100
        }
    }
    if val == 111 {
        print("  PASS: val = 111\n")
    } else {
        print("  FAIL: val = ")
        print(val)
        print("\n")
        exit(1)
    }

    // Test 6: while loop with accumulator
    print("\nTest 6: while loop accumulator\n")
    acc = 0
    n = 1
    while n <= 10 {
        acc = acc + n
        n = n + 1
    }
    if acc == 55 {
        print("  PASS: sum 1..10 = 55\n")
    } else {
        print("  FAIL: acc = ")
        print(acc)
        print("\n")
        exit(1)
    }

    print("\n=== All Scope Tests Passed ===\n")
}
