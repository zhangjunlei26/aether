// Test string comparison NULL safety
// Verifies: strcmp wrapped with _aether_safe_str to prevent NULL crashes

main() {
    print("=== String Comparison Null Safety Tests ===\n\n")

    // Test 1: Normal string comparison
    print("Test 1: Normal comparison\n")
    a = "hello"
    b = "hello"
    if a != b { print("  FAIL equal\n"); exit(1) }
    c = "world"
    if a == c { print("  FAIL not equal\n"); exit(1) }
    print("  PASS\n")

    // Test 2: String ordering
    print("\nTest 2: String ordering\n")
    if "abc" > "abd" { print("  FAIL\n"); exit(1) }
    if "abd" < "abc" { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 3: Empty string comparison
    print("\nTest 3: Empty string\n")
    empty = ""
    if empty == "notempty" { print("  FAIL\n"); exit(1) }
    if empty != "" { print("  FAIL empty==empty\n"); exit(1) }
    print("  PASS\n")

    print("\n=== All 3 String Compare Tests Passed ===\n")
}
