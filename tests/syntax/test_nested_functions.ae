// Test nested and chained function calls
// Verifies: complex call patterns, recursion, higher-order nesting

double(x) {
    return x * 2
}

add(a, b) {
    return a + b
}

max(a, b) {
    if a > b { return a }
    return b
}

min(a, b) {
    if a < b { return a }
    return b
}

clamp(val, lo, hi) {
    return max(lo, min(val, hi))
}

main() {
    print("=== Nested Function Tests ===\n\n")

    // Test 1: Nested calls
    print("Test 1: Nested calls\n")
    if double(double(3)) != 12 { print("  FAIL\n"); exit(1) }
    if add(double(2), double(3)) != 10 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 2: Three-deep nesting
    print("\nTest 2: Three-deep nesting\n")
    result = max(min(max(1, 2), 5), min(3, 4))
    if result != 3 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 3: Clamp via composition
    print("\nTest 3: Clamp composition\n")
    if clamp(15, 0, 10) != 10 { print("  FAIL high\n"); exit(1) }
    if clamp(-5, 0, 10) != 0 { print("  FAIL low\n"); exit(1) }
    if clamp(5, 0, 10) != 5 { print("  FAIL mid\n"); exit(1) }
    print("  PASS\n")

    // Test 4: Function call as condition
    print("\nTest 4: Call in condition\n")
    if max(1, 2) != 2 { print("  FAIL\n"); exit(1) }
    if min(1, 2) != 1 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 5: Function call in arithmetic
    print("\nTest 5: Call in arithmetic\n")
    x = add(1, 2) * double(3)
    if x != 18 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    print("\n=== All 5 Nested Function Tests Passed ===\n")
}
