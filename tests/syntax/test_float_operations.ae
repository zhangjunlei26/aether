// Test float arithmetic, comparisons, and mixed int/float operations
// Covers: float literals, arithmetic, comparisons, int-float promotion

main() {
    print("=== Float Operations Tests ===\n\n")

    // Test 1: float literal assignment
    print("Test 1: float literals\n")
    x = 3.14
    y = 2.0
    if x > 3.0 {
        print("  PASS: 3.14 > 3.0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: float arithmetic
    print("\nTest 2: float arithmetic\n")
    sum = x + y
    if sum > 5.1 {
        print("  PASS: 3.14 + 2.0 > 5.1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    diff = x - y
    if diff > 1.1 {
        print("  PASS: 3.14 - 2.0 > 1.1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    prod = x * y
    if prod > 6.2 {
        print("  PASS: 3.14 * 2.0 > 6.2\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    quot = x / y
    if quot > 1.5 {
        print("  PASS: 3.14 / 2.0 > 1.5\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 3: float comparisons
    print("\nTest 3: float comparisons\n")
    a = 1.5
    b = 2.5
    if a < b {
        print("  PASS: 1.5 < 2.5\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if b > a {
        print("  PASS: 2.5 > 1.5\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if a <= 1.5 {
        print("  PASS: 1.5 <= 1.5\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if b >= 2.5 {
        print("  PASS: 2.5 >= 2.5\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 4: float equality (exact values)
    print("\nTest 4: float equality\n")
    c = 1.0
    d = 1.0
    if c == d {
        print("  PASS: 1.0 == 1.0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if c != 2.0 {
        print("  PASS: 1.0 != 2.0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 5: negative floats
    print("\nTest 5: negative floats\n")
    neg = -3.5
    if neg < 0.0 {
        print("  PASS: -3.5 < 0.0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    pos = neg + 4.0
    if pos > 0.0 {
        print("  PASS: -3.5 + 4.0 > 0.0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 6: float in loop
    print("\nTest 6: float accumulation in loop\n")
    total = 0.0
    for i in 0..10 {
        total = total + 1.5
    }
    // 10 * 1.5 = 15.0
    if total > 14.9 {
        if total < 15.1 {
            print("  PASS: 10 * 1.5 ~ 15.0\n")
        } else {
            print("  FAIL: too high\n")
            exit(1)
        }
    } else {
        print("  FAIL: too low\n")
        exit(1)
    }

    print("\n=== All Float Operations Tests Passed ===\n")
}
