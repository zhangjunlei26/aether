// Test std.math module functions via namespace calls
// Verifies: math namespace resolution + float/double ABI correctness

import std.math

main() {
    print("=== Math Stdlib Tests ===\n\n")

    // Test 1: sqrt
    print("Test 1: math.sqrt\n")
    sq = math.sqrt(16.0)
    if sq < 3.99 { print("  FAIL: sqrt(16)="); println(sq); exit(1) }
    if sq > 4.01 { print("  FAIL: sqrt(16)="); println(sq); exit(1) }
    print("  PASS\n")

    // Test 2: abs_int
    print("\nTest 2: math.abs_int\n")
    a = math.abs_int(-42)
    if a != 42 { print("  FAIL\n"); exit(1) }
    a2 = math.abs_int(0)
    if a2 != 0 { print("  FAIL zero\n"); exit(1) }
    print("  PASS\n")

    // Test 3: min/max int
    print("\nTest 3: math.min_int / math.max_int\n")
    lo = math.min_int(3, 7)
    if lo != 3 { print("  FAIL min\n"); exit(1) }
    hi = math.max_int(3, 7)
    if hi != 7 { print("  FAIL max\n"); exit(1) }
    print("  PASS\n")

    // Test 4: clamp_int
    print("\nTest 4: math.clamp_int\n")
    c1 = math.clamp_int(15, 0, 10)
    if c1 != 10 { print("  FAIL high\n"); exit(1) }
    c2 = math.clamp_int(-5, 0, 10)
    if c2 != 0 { print("  FAIL low\n"); exit(1) }
    c3 = math.clamp_int(5, 0, 10)
    if c3 != 5 { print("  FAIL mid\n"); exit(1) }
    print("  PASS\n")

    // Test 5: sin/cos at known values
    print("\nTest 5: math.sin / math.cos\n")
    s0 = math.sin(0.0)
    if s0 > 0.01 { print("  FAIL sin(0)\n"); exit(1) }
    if s0 < -0.01 { print("  FAIL sin(0)\n"); exit(1) }
    c0 = math.cos(0.0)
    if c0 < 0.99 { print("  FAIL cos(0)\n"); exit(1) }
    if c0 > 1.01 { print("  FAIL cos(0)\n"); exit(1) }
    print("  PASS\n")

    // Test 6: pow
    print("\nTest 6: math.pow\n")
    p = math.pow(2.0, 10.0)
    if p < 1023.0 { print("  FAIL pow(2,10)\n"); exit(1) }
    if p > 1025.0 { print("  FAIL pow(2,10)\n"); exit(1) }
    print("  PASS\n")

    // Test 7: floor/ceil/round
    print("\nTest 7: math.floor / ceil / round\n")
    fl = math.floor(3.7)
    if fl < 2.99 { print("  FAIL floor\n"); exit(1) }
    if fl > 3.01 { print("  FAIL floor\n"); exit(1) }
    ce = math.ceil(3.2)
    if ce < 3.99 { print("  FAIL ceil\n"); exit(1) }
    if ce > 4.01 { print("  FAIL ceil\n"); exit(1) }
    rn = math.round(3.6)
    if rn < 3.99 { print("  FAIL round\n"); exit(1) }
    if rn > 4.01 { print("  FAIL round\n"); exit(1) }
    print("  PASS\n")

    // Test 8: random
    print("\nTest 8: math.random_int\n")
    math.random_seed(42)
    r = math.random_int(1, 100)
    if r < 1 { print("  FAIL range low\n"); exit(1) }
    if r > 100 { print("  FAIL range high\n"); exit(1) }
    print("  PASS\n")

    print("\n=== All 8 Math Tests Passed ===\n")
}
