// Test: actor setup phase — spawn with active=0, activate on first send.
// Spawning must not cause the actor to run. Wiring (aliasing the ref,
// using it in expressions) must be safe before any message is sent.
// Only the first message send activates the actor.

message Add { value: int }
message GetResult {}

actor Accumulator {
    state total = 0

    receive {
        Add(value) -> {
            total = total + value
        }
        GetResult() -> {
            print(total)
            print("\n")
        }
    }
}

main() {
    acc = spawn(Accumulator())

    // Alias the ref without sending — actor remains inactive.
    ref = acc

    // Activate via first send, then accumulate more.
    ref ! Add { value: 100 }
    ref ! Add { value: 42 }
    ref ! GetResult {}

    wait_for_idle()
    print("setup phase ok\n")
}
