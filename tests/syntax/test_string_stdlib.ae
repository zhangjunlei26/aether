// Test std.string module operations
// Covers: new, length, concat, substring, trim, split, starts_with, ends_with,
//         contains, index_of, to_upper, to_lower, to_cstr, from_int, equals, compare

import std.string

main() {
    print("=== String Stdlib Tests ===\n\n")

    // Test 1: new and length
    print("Test 1: new + length\n")
    s = string.new("hello")
    defer string.release(s)
    if string.length(s) == 5 {
        print("  PASS: length('hello') = 5\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: empty string
    print("\nTest 2: empty string\n")
    e = string.empty()
    defer string.release(e)
    if string.length(e) == 0 {
        print("  PASS: length('') = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 3: concat
    print("\nTest 3: concat\n")
    a = string.new("hello")
    b = string.new(" world")
    c = string.concat(a, b)
    defer string.release(a)
    defer string.release(b)
    defer string.release(c)
    if string.length(c) == 11 {
        print("  PASS: length('hello' + ' world') = 11\n")
    } else {
        print("  FAIL: length = ")
        print(string.length(c))
        print("\n")
        exit(1)
    }

    // Test 4: starts_with / ends_with
    print("\nTest 4: starts_with / ends_with\n")
    if string.starts_with(c, "hello") == 1 {
        print("  PASS: starts_with('hello')\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if string.ends_with(c, "world") == 1 {
        print("  PASS: ends_with('world')\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 5: contains / index_of
    print("\nTest 5: contains / index_of\n")
    if string.contains(c, "lo w") == 1 {
        print("  PASS: contains('lo w')\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    idx = string.index_of(c, "world")
    if idx == 6 {
        print("  PASS: index_of('world') = 6\n")
    } else {
        print("  FAIL: idx = ")
        print(idx)
        print("\n")
        exit(1)
    }

    // Test 6: substring
    print("\nTest 6: substring\n")
    sub = string.substring(c, 0, 5)
    defer string.release(sub)
    cstr = string.to_cstr(sub)
    if cstr == "hello" {
        print("  PASS: substring(0,5) = 'hello'\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 7: to_upper / to_lower
    print("\nTest 7: to_upper / to_lower\n")
    up = string.to_upper(s)
    defer string.release(up)
    up_cstr = string.to_cstr(up)
    if up_cstr == "HELLO" {
        print("  PASS: to_upper('hello') = 'HELLO'\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    low = string.to_lower(up)
    defer string.release(low)
    low_cstr = string.to_cstr(low)
    if low_cstr == "hello" {
        print("  PASS: to_lower('HELLO') = 'hello'\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 8: trim
    print("\nTest 8: trim\n")
    padded = string.new("  hello  ")
    defer string.release(padded)
    trimmed = string.trim(padded)
    defer string.release(trimmed)
    if string.length(trimmed) == 5 {
        print("  PASS: trim('  hello  ') length = 5\n")
    } else {
        print("  FAIL: length = ")
        print(string.length(trimmed))
        print("\n")
        exit(1)
    }

    // Test 9: equals / compare
    print("\nTest 9: equals / compare\n")
    x = string.new("abc")
    y = string.new("abc")
    z = string.new("xyz")
    defer string.release(x)
    defer string.release(y)
    defer string.release(z)
    if string.equals(x, y) == 1 {
        print("  PASS: equals('abc', 'abc')\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if string.equals(x, z) == 0 {
        print("  PASS: !equals('abc', 'xyz')\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    cmp = string.compare(x, z)
    if cmp < 0 {
        print("  PASS: compare('abc', 'xyz') < 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 10: from_int / to_cstr
    print("\nTest 10: from_int + to_cstr\n")
    num = string.from_int(42)
    defer string.release(num)
    num_cstr = string.to_cstr(num)
    if num_cstr == "42" {
        print("  PASS: from_int(42) = '42'\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 11: split
    print("\nTest 11: split\n")
    csv = string.new("one,two,three")
    defer string.release(csv)
    parts = string.split(csv, ",")
    defer string.array_free(parts)
    count = string.array_size(parts)
    if count == 3 {
        print("  PASS: split('one,two,three', ',') = 3 parts\n")
    } else {
        print("  FAIL: count = ")
        print(count)
        print("\n")
        exit(1)
    }
    p0 = string.array_get(parts, 0)
    if string.to_cstr(p0) == "one" {
        print("  PASS: parts[0] = 'one'\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    p2 = string.array_get(parts, 2)
    if string.to_cstr(p2) == "three" {
        print("  PASS: parts[2] = 'three'\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 12: char_at
    print("\nTest 12: char_at\n")
    ch = string.char_at(s, 0)
    if ch == 104 {
        print("  PASS: char_at('hello', 0) = 104 ('h')\n")
    } else {
        print("  FAIL: ch = ")
        print(ch)
        print("\n")
        exit(1)
    }

    print("\n=== All String Stdlib Tests Passed ===\n")
}
