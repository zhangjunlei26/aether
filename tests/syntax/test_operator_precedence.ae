// Test operator precedence and associativity
// Verifies: correct parsing of complex expressions

main() {
    print("=== Operator Precedence Tests ===\n\n")

    // Test 1: Multiplication before addition
    print("Test 1: * before +\n")
    if 2 + 3 * 4 != 14 { print("  FAIL\n"); exit(1) }
    if 3 * 4 + 2 != 14 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 2: Division before subtraction
    print("\nTest 2: / before -\n")
    if 10 - 6 / 2 != 7 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 3: Parentheses override
    print("\nTest 3: Parentheses\n")
    if (2 + 3) * 4 != 20 { print("  FAIL\n"); exit(1) }
    if 2 * (3 + 4) != 14 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 4: Modulo
    print("\nTest 4: Modulo\n")
    if 17 % 5 != 2 { print("  FAIL\n"); exit(1) }
    if 10 % 3 + 1 != 2 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    // Test 5: Comparison returns bool (0 or 1 in int context)
    print("\nTest 5: Comparison operators\n")
    if 3 < 5 != true { print("  FAIL <\n"); exit(1) }
    if 5 < 3 != false { print("  FAIL < false\n"); exit(1) }
    if 5 > 3 != true { print("  FAIL >\n"); exit(1) }
    if 3 >= 3 != true { print("  FAIL >=\n"); exit(1) }
    if 3 <= 3 != true { print("  FAIL <=\n"); exit(1) }
    print("  PASS\n")

    // Test 6: Logical AND/OR
    print("\nTest 6: Logical operators\n")
    if !(true && true) { print("  FAIL &&\n"); exit(1) }
    if true && false { print("  FAIL && false\n"); exit(1) }
    if !(true || false) { print("  FAIL ||\n"); exit(1) }
    if false || false { print("  FAIL || false\n"); exit(1) }
    print("  PASS\n")

    // Test 7: Unary negation
    print("\nTest 7: Unary negation\n")
    x = 5
    if -x != -5 { print("  FAIL\n"); exit(1) }
    y = -x
    if -y != 5 { print("  FAIL double neg\n"); exit(1) }
    print("  PASS\n")

    // Test 8: Complex mixed expression
    print("\nTest 8: Complex expression\n")
    result = (2 + 3) * 4 - 10 / 2
    if result != 15 { print("  FAIL\n"); exit(1) }
    print("  PASS\n")

    print("\n=== All 8 Precedence Tests Passed ===\n")
}
