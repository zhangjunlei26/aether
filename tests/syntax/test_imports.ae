// Test import and import aliasing syntax
// Verifies the parser and type checker handle import statements correctly
//
// Note: imported modules don't resolve to real files in this test,
// but the syntax should parse and type-check without errors.

import std.math
import std.collections as col
import std.log as Log

message TestMessage { value: int }

actor TestActor {
    state received = 0;

    receive {
        TestMessage(value) -> {
            received = received + 1;
            print("Received: ");
            print(value);
            print("\n");
        }
    }
}

main() {
    print("=== Import Syntax Tests ===\n\n")

    print("Test 1: Basic import parsed\n")
    print("  PASS: import std.math accepted\n")

    print("\nTest 2: Import with alias parsed\n")
    print("  PASS: import std.collections as col accepted\n")

    print("\nTest 3: Multiple aliased imports parsed\n")
    print("  PASS: import std.log as Log accepted\n")

    // Test actor still works alongside imports
    print("\nTest 4: Actor with imports\n")
    test = spawn(TestActor());
    test ! TestMessage { value: 42 };
    print("  PASS: actor spawned and message sent\n")

    print("\n=== All 4 Tests Complete ===\n")
}
