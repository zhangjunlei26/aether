// Test std.map operations
// Covers: map.new, map.put, map.get, map.has, map.remove, map.size, map.clear

import std.map
import std.string

main() {
    print("=== Map Operations Tests ===\n\n")

    // Test 1: Create map and check initial size
    print("Test 1: create map\n")
    m = map.new()
    defer map.free(m)
    if map.size(m) == 0 {
        print("  PASS: initial size = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: Put and size
    print("\nTest 2: put entries\n")
    v1 = string.new("hello")
    v2 = string.new("world")
    map.put(m, "key1", v1)
    map.put(m, "key2", v2)
    if map.size(m) == 2 {
        print("  PASS: size = 2 after 2 puts\n")
    } else {
        print("  FAIL: size = ")
        print(map.size(m))
        print("\n")
        exit(1)
    }

    // Test 3: has() check
    print("\nTest 3: has() check\n")
    if map.has(m, "key1") == 1 {
        print("  PASS: has('key1') = 1\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if map.has(m, "missing") == 0 {
        print("  PASS: has('missing') = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 4: get() retrieves correct value
    print("\nTest 4: get() retrieves value\n")
    got = map.get(m, "key1")
    len = string.length(got)
    if len == 5 {
        print("  PASS: length of value for 'key1' = 5 (hello)\n")
    } else {
        print("  FAIL: length = ")
        print(len)
        print("\n")
        exit(1)
    }

    // Test 5: remove()
    print("\nTest 5: remove()\n")
    map.remove(m, "key1")
    if map.has(m, "key1") == 0 {
        print("  PASS: key1 removed\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }
    if map.size(m) == 1 {
        print("  PASS: size = 1 after remove\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 6: clear()
    print("\nTest 6: clear()\n")
    map.clear(m)
    if map.size(m) == 0 {
        print("  PASS: size = 0 after clear\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Cleanup
    string.release(v1)
    string.release(v2)

    print("\n=== All Map Operations Tests Passed ===\n")
}
