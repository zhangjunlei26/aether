// Test: Self-send pattern in cooperative mode
// Verifies: an actor can send messages to itself and they
// are processed correctly by the cooperative scheduler.
// This exercises the FIFO ordering edge case where the
// sync path step() may process a different message than
// the one just sent.

message Count { n: int }
message Done {}

actor SelfCounter {
    state total = 0;
    state self_ref = 0;

    receive {
        Count(n) -> {
            total = total + 1;
            if n > 1 {
                // Self-send: decrement and continue
                self_ref ! Count { n: n - 1 };
            }
        }
        Done() -> {
            println("  total: ${total}");
        }
    }
}

message Tick {}
message Report {}

actor Ticker {
    state ticks = 0;
    state self_ref = 0;
    state limit = 0;

    receive {
        Tick() -> {
            ticks = ticks + 1;
            if ticks < limit {
                self_ref ! Tick {};
            }
        }
        Report() -> {
            println("  ticks: ${ticks}");
        }
    }
}

main() {
    println("=== Self-Send Cooperative Test ===");
    println("");

    // Test 1: Self-send countdown
    println("Test 1: Self-send countdown from 5");
    c = spawn(SelfCounter());
    c.self_ref = c;
    c ! Count { n: 5 };
    wait_for_idle();
    c ! Done {};
    wait_for_idle();
    if c.total == 5 {
        println("  PASS: counted 5 self-sends");
    } else {
        println("  FAIL: expected 5");
        exit(1);
    }

    // Test 2: Self-send tick loop
    println("Test 2: Self-send tick to 10");
    t = spawn(Ticker());
    t.self_ref = t;
    t.limit = 10;
    t ! Tick {};
    wait_for_idle();
    t ! Report {};
    wait_for_idle();
    if t.ticks == 10 {
        println("  PASS: ticked 10 times");
    } else {
        println("  FAIL: expected 10 ticks");
        exit(1);
    }

    // Test 3: Multiple actors self-sending simultaneously
    println("Test 3: Two actors self-sending concurrently");
    a1 = spawn(SelfCounter());
    a1.self_ref = a1;
    a2 = spawn(SelfCounter());
    a2.self_ref = a2;
    a1 ! Count { n: 3 };
    a2 ! Count { n: 4 };
    wait_for_idle();
    a1 ! Done {};
    a2 ! Done {};
    wait_for_idle();
    if a1.total == 3 {
        println("  PASS: actor 1 counted 3");
    } else {
        println("  FAIL: actor 1 expected 3");
        exit(1);
    }
    if a2.total == 4 {
        println("  PASS: actor 2 counted 4");
    } else {
        println("  FAIL: actor 2 expected 4");
        exit(1);
    }

    println("");
    println("All self-send tests passed!");
}
