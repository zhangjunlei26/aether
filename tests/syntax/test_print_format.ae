// Test: print/println format specifier auto-fix
// Verifies: format specifiers are corrected to match argument types
// Covers: %s with int, %d with string, mixed types, multiple args

main() {
    println("=== Print Format Tests ===")

    // Test 1: Basic %d with int (no fix needed)
    print("Test 1: ")
    print("%d\n", 42)

    // Test 2: %s with int arg — auto-fixed to %d
    print("Test 2: ")
    print("%s\n", 100)

    // Test 3: %d with string arg — auto-fixed to %s
    print("Test 3: ")
    print("%d\n", "hello")

    // Test 4: Multiple args with wrong specifiers
    print("Test 4: ")
    print("%s %s\n", 10, 20)

    // Test 5: Mixed correct and incorrect specifiers
    print("Test 5: ")
    print("%d %s\n", 42, "world")

    // Test 6: Float with %d — auto-fixed to %f
    print("Test 6: ")
    print("%d\n", 3.14)

    // Test 7: println with format string
    print("Test 7: ")
    println("%s", 999)

    // Test 8: Escaped percent %%
    print("Test 8: ")
    print("100%% done\n")

    // Test 9: Format with width/padding
    print("Test 9: ")
    print("num=%s\n", 7)

    // Test 10: Bool with format
    print("Test 10: ")
    print("flag=%s\n", true)

    // Test 11: No format string, just value
    print("Test 11: ")
    print(42)
    print("\n")

    // Test 12: println with different types
    print("Test 12: ")
    println(3.14)

    println("\n=== All Print Format Tests Done ===")
}
