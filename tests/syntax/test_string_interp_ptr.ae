// Test: string interpolation as values (heap-allocated path)
// Verifies that interpolated strings can be stored, returned from functions,
// passed around as ptr values, and handle various types

format_msg(n) -> {
    msg = "count=${n}"
    msg
}

main() {
    // Integer interpolation
    x = 42
    s = "value: ${x}"
    println(s)

    // String interpolation
    name = "world"
    greeting = "hello ${name}"
    println(greeting)

    // Expression interpolation
    a = 3
    b = 4
    expr_result = "${a} + ${b} = ${a + b}"
    println(expr_result)

    // Returned from a function
    result = format_msg(7)
    println(result)

    // In a conditional
    flag = 1
    label = if flag == 1 { "on: ${flag}" } else { "off: ${flag}" }
    println(label)

    // Multiple interpolated strings
    m1 = "first: ${1}"
    m2 = "second: ${2}"
    println(m1)
    println(m2)
}
