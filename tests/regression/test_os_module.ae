// Regression test: std.os module
// Covers: system, exec, getenv

import std.os
import std.string

main() {
    print("=== OS Module Tests ===\n")

    // Test 1: os.system returns 0 on success
    print("\nTest 1: os.system success\n")
    code = os.system("true")
    if code == 0 {
        print("  PASS: exit code = 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 2: os.system returns non-zero on failure
    print("\nTest 2: os.system failure\n")
    code2 = os.system("false")
    if code2 != 0 {
        print("  PASS: exit code != 0\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 3: os.exec captures output
    print("\nTest 3: os.exec captures output\n")
    output = os.exec("echo hello")
    if output != 0 {
        if string.contains(output, "hello") == 1 {
            print("  PASS: captured 'hello'\n")
        } else {
            print("  FAIL: output doesn't contain 'hello'\n")
            exit(1)
        }
    } else {
        print("  FAIL: exec returned NULL\n")
        exit(1)
    }

    // Test 4: os.exec multi-line output
    print("\nTest 4: os.exec multi-line\n")
    output2 = os.exec("echo line1 && echo line2")
    if output2 != 0 {
        if string.contains(output2, "line1") == 1 {
            if string.contains(output2, "line2") == 1 {
                print("  PASS: captured both lines\n")
            } else {
                print("  FAIL: missing line2\n")
                exit(1)
            }
        } else {
            print("  FAIL: missing line1\n")
            exit(1)
        }
    } else {
        print("  FAIL: exec returned NULL\n")
        exit(1)
    }

    // Test 5: os.getenv known variable
    print("\nTest 5: os.getenv PATH\n")
    path = os.getenv("PATH")
    if path != 0 {
        print("  PASS: PATH is set\n")
    } else {
        print("  FAIL: PATH not found\n")
        exit(1)
    }

    // Test 6: os.getenv unknown variable
    print("\nTest 6: os.getenv unknown\n")
    unknown = os.getenv("AETHER_NONEXISTENT_VAR_XYZ_999")
    if unknown == 0 {
        print("  PASS: unknown var returns NULL\n")
    } else {
        print("  FAIL\n")
        exit(1)
    }

    // Test 7: os.getenv HOME
    print("\nTest 7: os.getenv HOME\n")
    home = os.getenv("HOME")
    if home != 0 {
        if string.length(home) > 0 {
            print("  PASS: HOME is non-empty\n")
        } else {
            print("  FAIL: HOME is empty\n")
            exit(1)
        }
    } else {
        print("  FAIL: HOME not found\n")
        exit(1)
    }

    print("\n=== All OS Module Tests Passed ===\n")
}
