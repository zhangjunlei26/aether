// Regression test for GitHub issue #56
// Escape sequences \n \t \r \\ \" in interpolated strings emitted raw
// This test verifies that escape sequences are correctly interpreted.

main() {
    println("=== Issue #56: escape sequences in strings ===")

    x = 42
    y = "world"

    result1 = "hello\tworld"
    print("Test tab literal: ")
    println(result1)

    print("Test newline in interp: line1\nline2\n")

    print("Test tab in interp: col1\tcol2\n")

    print("Test backslash: path\\to\\file\n")

    print("Test quote: she said \"hi\"\n")

    print("Test hex A: \x41\n")
    print("Test octal A: \101\n")

    v = 10
    print("Interp with escapes: val=${v}\ttab\n")

    name = "Aether"
    print("Hello ${name}\tnewline\n")

    println("PASS: all escape sequences rendered correctly")
    println("=== Issue #56: ALL PASS ===")
}
