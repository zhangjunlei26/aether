// Regression test for GitHub issue #44
// print/println format specifier mismatch causes segfault or garbage output
// The typechecker now warns and the codegen auto-corrects mismatched specifiers.

main() {
    println("=== Issue #44: format specifier auto-correction ===")

    // %s with int -> auto-corrected to %d
    print("int via %%s: ")
    print("%s\n", 42)

    // %d with string -> auto-corrected to %s
    print("str via %%d: ")
    print("%d\n", "hello")

    // %d with float -> auto-corrected to %f
    print("float via %%d: ")
    print("%d\n", 3.14)

    // correct specifiers (no correction needed)
    print("correct int: ")
    print("%d\n", 100)

    print("correct str: ")
    print("%s\n", "ok")

    print("correct float: ")
    print("%f\n", 2.718)

    // multiple args with mixed correctness
    print("mixed: ")
    print("%s %d\n", 7, "text")

    // bool with %s -> auto-corrected to %d
    print("bool via %%s: ")
    print("%s\n", true)

    // escaped percent
    print("escaped: 100%% done\n")

    println("PASS: all format specifiers handled without crash")
    println("=== Issue #44: ALL PASS ===")
}
