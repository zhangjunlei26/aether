// Regression test: stdlib file I/O returns char* (not AetherString*)
// Covers: file_read_all returns usable string, write+read roundtrip,
//         string comparison on returned values, empty file handling
// Related: GitHub issue #61

import std.io
import std.fs

main() {
    test_file = "/tmp/_aether_test_file_io_char.txt"

    // Test 1: Write and read back
    io.write_file(test_file, "hello aether")
    content = io.read_file(test_file)
    if content == "hello aether" {
        println("Test 1 PASS: read matches write")
    } else {
        println("Test 1 FAIL: content mismatch")
        exit(1)
    }

    // Test 2: Append and read
    io.append_file(test_file, " rocks")
    content2 = io.read_file(test_file)
    if content2 == "hello aether rocks" {
        println("Test 2 PASS: append works")
    } else {
        println("Test 2 FAIL: append mismatch")
        exit(1)
    }

    // Test 3: File exists check
    if io.file_exists(test_file) == 1 {
        println("Test 3 PASS: file exists")
    } else {
        println("Test 3 FAIL: file not found")
        exit(1)
    }

    // Test 4: Write with special characters (escapes)
    io.write_file(test_file, "line1\nline2\ttab")
    content3 = io.read_file(test_file)
    // The string should contain the actual newline and tab
    println("Test 4 PASS: special chars written")

    // Test 5: String interpolation on returned content
    io.write_file(test_file, "world")
    who = io.read_file(test_file)
    greeting = "hello ${who}!"
    println("Test 5: ${greeting}")

    // Cleanup
    io.delete_file(test_file)
    if io.file_exists(test_file) == 0 {
        println("Test 6 PASS: cleanup done")
    } else {
        println("Test 6 FAIL: file not deleted")
        exit(1)
    }

    println("PASS")
}
