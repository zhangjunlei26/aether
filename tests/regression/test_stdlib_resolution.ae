// Regression test for GitHub issue #54
// ae version use fails on Windows (symlinks, binary discovery)
// This test verifies that the ae tool itself can be invoked and that
// AETHER_HOME is set so the compiler can find the stdlib.
// The fact that this file compiles and runs via ae.exe proves the
// toolchain discovery and AETHER_HOME injection work.

import std.string

main() {
    println("=== Issue #54: ae tool + AETHER_HOME ===")

    s = string.new("toolchain-ok")
    defer string.release(s)

    if string.length(s) == 12 {
        println("PASS: ae invoked aetherc, aetherc found stdlib via AETHER_HOME")
    } else {
        println("FAIL: unexpected string length")
        exit(1)
    }

    println("=== Issue #54: ALL PASS ===")
}
