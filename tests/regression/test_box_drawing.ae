// Regression test: ASCII box drawing — the core use case for CLI helper tools
// Covers: print_char for box chars, loops for rows/cols, string interpolation
//         inside draw functions, functions with string params, escape combos

draw_horizontal(width: int, left: int, right: int) {
    print_char(left)
    i = 0
    for i in 0..width {
        print_char(45)  // -
    }
    print_char(right)
    print_char(10)  // newline
}

draw_content_line(text: string, width: int) {
    print_char(124)  // |
    print_char(32)   // space
    print(text)
    // pad to width (text length approximated, just pad generously)
    j = 0
    for j in 0..width {
        print_char(32)
    }
    print_char(124)
    print_char(10)
}

draw_box(title: string, body: string, width: int) {
    draw_horizontal(width, 43, 43)       // +---+
    draw_content_line(title, width - 2)
    draw_horizontal(width, 43, 43)       // +---+
    draw_content_line(body, width - 2)
    draw_horizontal(width, 43, 43)       // +---+
}

// Draw with escape sequences for color
draw_colored_header(text: string) {
    println("\x1b[1m+====================+\x1b[0m")
    println("\x1b[1m| ${text}           |\x1b[0m")
    println("\x1b[1m+====================+\x1b[0m")
}

// Progress bar using print_char in a loop
draw_progress(pct: int) {
    width = 20
    filled = (pct * width) / 100
    print("[")
    i = 0
    for i in 0..width {
        if i < filled {
            print_char(61)  // =
        } else {
            print_char(32)  // space
        }
    }
    print("] ${pct}%")
    println("")
}

// Table row using tab escapes
print_row(col1: string, col2: string, col3: string) {
    println("${col1}\x09${col2}\x09${col3}")
}

main() {
    // Test 1: Basic box
    println("Test 1: Box")
    draw_box("Title", "Content", 20)
    println("")

    // Test 2: Colored header with escape sequences
    println("Test 2: Colored")
    draw_colored_header("Header")
    println("")

    // Test 3: Progress bars at different levels
    println("Test 3: Progress")
    draw_progress(0)
    draw_progress(25)
    draw_progress(50)
    draw_progress(75)
    draw_progress(100)
    println("")

    // Test 4: Table with tab alignment
    println("Test 4: Table")
    println("Name\x09Age\x09City")
    println("----\x09---\x09----")
    print_row("Alice", "30", "NYC")
    print_row("Bob", "25", "LA")
    print_row("Teuvo", "28", "Helsinki")
    println("")

    // Test 5: Nested boxes (box within output)
    println("Test 5: Nested")
    draw_horizontal(30, 43, 43)
    draw_content_line("Outer box", 28)
    print_char(124)
    print(" ")
    // Inner box inline
    print("+--------+")
    j = 0
    for j in 0..17 {
        print_char(32)
    }
    println("|")
    print_char(124)
    print(" ")
    print("| Inner  |")
    for j in 0..17 {
        print_char(32)
    }
    println("|")
    print_char(124)
    print(" ")
    print("+--------+")
    for j in 0..17 {
        print_char(32)
    }
    println("|")
    draw_horizontal(30, 43, 43)

    println("")
    println("PASS")
}
