// Regression test for GitHub issue #47
// ActorRef* is undefined C type in generated code
// The codegen now emits void* for unresolved actor refs.
// This test exercises actor spawning and message passing with actor refs.

message Ping { sender: ptr }
message Pong { }
message Report { count: int }

actor PingActor {
    state pong_count = 0

    receive {
        Pong() -> {
            pong_count = pong_count + 1
        }
        Report(count) -> {
            if count == pong_count {
                print("PASS: received ")
                print(pong_count)
                println(" pongs")
            } else {
                print("FAIL: expected ")
                print(count)
                print(" pongs, got ")
                println(pong_count)
            }
        }
    }
}

actor PongActor {
    receive {
        Ping(sender) -> {
            sender ! Pong {}
        }
    }
}

main() {
    println("=== Issue #47: ActorRef codegen ===")

    pinger = spawn(PingActor())
    ponger = spawn(PongActor())

    ponger ! Ping { sender: pinger }
    ponger ! Ping { sender: pinger }
    ponger ! Ping { sender: pinger }

    sleep(300)

    pinger ! Report { count: 3 }
    sleep(200)

    println("PASS: actor ref messages compiled and executed")
    println("=== Issue #47: ALL PASS ===")
}
