// Regression test: print_char and escape sequences inside actor handlers
// Covers: print_char from receive blocks, ANSI escapes in actor output,
//         self-send animation loops, multiple actors with formatted output

message Draw { frame: int }
message Label { text: string }
message Stop {}

// Actor that draws a progress bar using print_char
actor ProgressBar {
    state width = 10
    state done = 0

    receive {
        Draw(frame) -> {
            print_char(91)   // [
            i = 0
            for i in 0..width {
                if i < frame {
                    print_char(35)   // #
                } else {
                    print_char(45)   // -
                }
            }
            print_char(93)   // ]
            println("")
            done = 1
        }
    }
}

// Actor that uses escape sequences in output
actor Formatter {
    state count = 0

    receive {
        Label(text) -> {
            count = count + 1
            // Use hex escape for tab alignment
            println("${count}:\x09${text}")
        }
        Stop() -> {
            println("Formatter done (${count} labels)")
        }
    }
}

// Actor with self-send loop using print_char
actor Spinner {
    state max = 4

    receive {
        Draw(frame) -> {
            // Spinner chars: | / - backslash
            idx = frame % 4
            if idx == 0 { print_char(124) }
            if idx == 1 { print_char(47) }
            if idx == 2 { print_char(45) }
            if idx == 3 { print_char(92) }
            print_char(32)

            if frame < max {
                self ! Draw { frame: frame + 1 }
            } else {
                println("")
                println("Spin done")
            }
        }
    }
}

main() {
    // Test 1: print_char in actor handler (progress bar)
    println("Test 1: print_char in actor")
    pb = spawn(ProgressBar())
    pb ! Draw { frame: 7 }
    wait_for_idle()

    // Test 2: escape sequences in actor output
    println("Test 2: escapes in actor")
    fmt = spawn(Formatter())
    fmt ! Label { text: "first" }
    fmt ! Label { text: "second" }
    fmt ! Label { text: "third" }
    fmt ! Stop {}
    wait_for_idle()

    // Test 3: self-send animation with print_char
    println("Test 3: self-send spinner")
    s = spawn(Spinner())
    s ! Draw { frame: 0 }
    wait_for_idle()

    println("PASS")
}
