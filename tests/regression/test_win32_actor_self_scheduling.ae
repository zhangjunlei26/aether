// Regression test for GitHub issue #46
// Linker errors on Windows (nanosleep, sched_yield, clock_gettime redefinition)
// Also tests: self-scheduling actor with external stop (StopAnimation pattern)
// If this compiles and runs with actors + sleep, the Windows compat shims work.

message Tick { n: int }
message AnimStart { }
message AnimStep { }
message AnimStop { }

actor Counter {
    state total = 0

    receive {
        Tick(n) -> {
            total = total + n
            if total >= 10 {
                print("PASS: counter reached ")
                println(total)
            }
        }
    }
}

actor Animator {
    state running = false
    state ticks = 0

    receive {
        AnimStart() -> {
            running = true
            self ! AnimStep {}
        }
        AnimStep() -> {
            if running {
                ticks = ticks + 1
                sleep(100)
                self ! AnimStep {}
            }
        }
        AnimStop() -> {
            running = false
            print("PASS: animator stopped after ")
            print(ticks)
            println(" ticks")
        }
    }
}

main() {
    println("=== Issue #46: Windows linker compat + self-scheduling stop ===")

    c = spawn(Counter())

    i = 1
    while i <= 4 {
        c ! Tick { n: i }
        sleep(50)
        i = i + 1
    }

    sleep(200)
    println("PASS: actors + sleep work (no linker errors)")

    anim = spawn(Animator())
    anim ! AnimStart {}
    sleep(400)
    anim ! AnimStop {}
    sleep(300)

    println("PASS: self-scheduling actor stopped cleanly")
    println("=== Issue #46: ALL PASS ===")
}
