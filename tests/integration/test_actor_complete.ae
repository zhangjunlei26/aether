message Increment { amount: int }
message GetValue {}

actor Counter {
    state count = 0;

    receive {
        Increment(amount) -> {
            count = count + amount;
        }
        GetValue() -> {
            print("Count: ");
            print(count);
            print("\n");
        }
    }
}

main() {
    counter = spawn(Counter());

    counter ! Increment { amount: 5 };
    counter ! Increment { amount: 3 };
    counter ! GetValue {};

    // Wait for all messages to be processed
    wait_for_idle();

    print("Final count: ");
    print(counter.count);
    print("\n");
    print("Actor complete test done\n");
}
