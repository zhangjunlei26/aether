// Test: Module with no export declarations — all symbols are public (backwards compat)

import helpers

main() {
    // Test 1: function accessible without export keyword
    println("test 1: function without export")
    result = helpers.triple(4)
    if result == 12 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 2: constant accessible without export keyword
    println("test 2: constant without export")
    if helpers.LIMIT == 100 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 3: function uses module constant internally
    println("test 3: internal constant reference")
    result = helpers.clamp(200)
    if result == 100 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 4: clamp below limit passes through
    println("test 4: clamp passthrough")
    result = helpers.clamp(50)
    if result == 50 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    println("")
    println("All 4 no-export tests passed!")
}
