message Increment {
    amount: int
}

message GetValue {
}

actor Counter {
    count: int

    state count: int = 0

    receive {
        Increment { amount } -> {
            count = count + amount;
        }
        GetValue {} -> {
            print(count);
        }
    }
}

main() {
    counter = spawn Counter;
    counter ! Increment { amount: 5 };
    counter ! Increment { amount: 3 };
    counter ! GetValue {};
    Counter_step(counter);
    Counter_step(counter);
    Counter_step(counter);
}
