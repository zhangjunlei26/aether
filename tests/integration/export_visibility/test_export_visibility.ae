// Test: Export visibility enforcement
// Modules with `export` only expose exported functions and constants.
// Non-exported symbols are private (used internally but not accessible from outside).

import mathlib

main() {
    // Test 1: exported function works
    println("test 1: exported function")
    result = mathlib.double_it(5)
    if result == 10 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 2: exported function with negative input
    println("test 2: exported function negative input")
    result = mathlib.add(10, 0 - 3)
    if result == 7 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 3: second exported function
    println("test 3: second exported function")
    result = mathlib.add(3, 4)
    if result == 7 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 4: exported constant
    println("test 4: exported constant")
    if mathlib.PI == 3 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 5: exported functions in expressions
    println("test 5: exported functions in expressions")
    result = mathlib.add(mathlib.double_it(3), mathlib.PI)
    if result == 9 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    println("")
    println("All 5 export visibility tests passed!")
}
