// Test: Pure module imports alongside stdlib imports

import calc
import std.string
import std.math

main() {
    // Test 1: pure module function
    println("test 1: pure module function")
    result = calc.square(5)
    if result == 25 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 2: stdlib string function
    println("test 2: stdlib string function")
    s = string.new("hello")
    len = string.length(s)
    string.release(s)
    if len == 5 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 3: stdlib math function
    println("test 3: stdlib math function")
    result = math.abs_int(0 - 7)
    if result == 7 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 4: pure module intra-module call
    println("test 4: intra-module call")
    result = calc.sum_of_squares(3, 4)
    if result == 25 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 5: mix pure + stdlib in one expression
    println("test 5: mixed expression")
    result = math.max_int(calc.square(3), calc.square(2))
    if result == 9 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    println("")
    println("All 5 mixed import tests passed!")
}
