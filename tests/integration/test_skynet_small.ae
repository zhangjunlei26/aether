// Skynet Smoke Test (CI)
// Runs a small recursive actor tree and verifies it completes without crashing.
// With 100 leaves: sum = 0+1+...+99 = 4950
// With 1000 leaves: sum = 0+1+...+999 = 499500

message Setup { self_ref: ptr }
message Spawn { offset: int, size: int, parent: ptr }
message Result { value: int }

actor SkynetNode {
    state my_ref = 0;
    state parent_ref = 0;
    state pending = 0;
    state total = 0;

    receive {
        Setup(self_ref) -> {
            my_ref = self_ref;
        }
        Spawn(offset, size, parent) -> {
            parent_ref = parent;
            if (size == 1) {
                parent_ref ! Result { value: offset };
            } else {
                pending = 10;
                child_size = size / 10;
                i = 0;
                while (i < 10) {
                    child = spawn(SkynetNode());
                    child ! Setup { self_ref: child };
                    child ! Spawn { offset: offset + i * child_size, size: child_size, parent: my_ref };
                    i = i + 1;
                }
            }
        }
        Result(value) -> {
            total = total + value;
            pending = pending - 1;
            if (pending == 0) {
                if (parent_ref != 0) {
                    parent_ref ! Result { value: total };
                }
            }
        }
    }
}

main() {
    // Use 100 leaves for fast CI: sum = 0+1+...+99 = 4950
    num_leaves = 100;

    root = spawn(SkynetNode());
    root ! Setup { self_ref: root };
    root ! Spawn { offset: 0, size: num_leaves, parent: 0 };

    wait_for_idle();

    // Sum of 0..99 = 4950
    print("skynet sum: ");
    print(root.total);
    print("\n");
}
