// String utility module — tests multi-import alongside mymath

export repeat_sum(x, times) {
    total = 0
    for (i = 0; i < times; i = i + 1) {
        total = total + x
    }
    return total
}

export const MAGIC = 7

// Private — not accessible from outside
internal_helper(x) {
    return x + 1
}
