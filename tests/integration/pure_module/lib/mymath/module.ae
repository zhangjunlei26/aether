const PI_APPROX = 3
const SCALE = 10

double_it(x) {
    return x * 2
}

// Uses a module constant inside a function body
scaled(x) {
    return x * SCALE
}

add(a, b) {
    return a + b
}

// Intra-module call: calls double_it and add from within the same module
double_and_add(x, y) {
    return add(double_it(x), y)
}

negate(x) {
    return 0 - x
}

// Chain of intra-module calls
abs_val(x) {
    if x < 0 {
        return negate(x)
    }
    return x
}

// Parameter shadows module constant SCALE — parameter should win
check_param_shadow(SCALE) {
    return SCALE
}

// Local variable shadows module constant PI_APPROX — local should win
check_local_shadow() {
    PI_APPROX = 99
    return PI_APPROX
}

// Constant referencing another constant
const DOUBLE_SCALE = SCALE * 2
