// Test: Pure Aether module imports
// Covers: basic functions, intra-module calls, constants, type inference,
//         nested expressions, shadowing, multi-module imports, cross-module expressions

import mymath
import strutil

main() {
    // Test 1: basic function call
    println("test 1: basic function")
    result = mymath.double_it(5)
    if result == 10 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 2: two-argument function
    println("test 2: two-arg function")
    result = mymath.add(3, 4)
    if result == 7 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 3: intra-module call (double_and_add calls double_it and add)
    println("test 3: intra-module calls")
    result = mymath.double_and_add(5, 3)
    if result == 13 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 4: module constant
    println("test 4: module constant")
    if mymath.PI_APPROX == 3 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 5: module function in expression
    println("test 5: function in expression")
    result = mymath.add(mymath.double_it(2), mymath.double_it(3))
    if result == 10 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 6: chained intra-module calls (abs_val calls negate)
    println("test 6: chained intra-module calls")
    result = mymath.abs_val(0 - 7)
    if result == 7 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 7: module function with local variables
    println("test 7: mixed local and module")
    x = 10
    y = mymath.add(x, mymath.negate(3))
    if y == 7 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 8: function using module constant internally
    println("test 8: function using module constant")
    result = mymath.scaled(5)
    if result == 50 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 9: multiple constants
    println("test 9: multiple constants")
    if mymath.SCALE == 10 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 10: parameter shadows module constant (SCALE param should win, not SCALE=10)
    println("test 10: parameter shadows constant")
    result = mymath.check_param_shadow(42)
    if result == 42 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 11: local variable shadows module constant (PI_APPROX=99 should win, not PI_APPROX=3)
    println("test 11: local variable shadows constant")
    result = mymath.check_local_shadow()
    if result == 99 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 12: constant referencing another constant (DOUBLE_SCALE = SCALE * 2 = 20)
    println("test 12: constant referencing constant")
    if mymath.DOUBLE_SCALE == 20 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 13: second module — basic function from strutil
    println("test 13: second module function")
    result = strutil.repeat_sum(3, 4)
    if result == 12 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 14: second module constant
    println("test 14: second module constant")
    if strutil.MAGIC == 7 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    // Test 15: cross-module expression (mymath + strutil in same expression)
    println("test 15: cross-module expression")
    result = mymath.add(strutil.MAGIC, mymath.double_it(strutil.repeat_sum(2, 3)))
    // strutil.repeat_sum(2, 3) = 6, mymath.double_it(6) = 12, mymath.add(7, 12) = 19
    if result == 19 {
        println("PASS")
    } else {
        println("FAIL")
        exit(1)
    }

    println("")
    println("All 15 pure module tests passed!")
}
