// Test actor-to-actor communication
// Covers: one actor sending messages to another actor (not just main -> actor),
//         bidirectional messaging, state-wiring, multiple wait_for_idle() phases

message Ping { seq: int }
message PingWithRef { sender_ref: int }
message Pong { seq: int }
message Go {}

actor PingActor {
    state pong_ref = 0
    state count = 0

    receive {
        Go() -> {
            // Send 5 pings to the pong actor via state-wired ref
            pong_ref ! Ping { seq: 1 }
            pong_ref ! Ping { seq: 2 }
            pong_ref ! Ping { seq: 3 }
            pong_ref ! Ping { seq: 4 }
            pong_ref ! Ping { seq: 5 }
        }
        Pong(seq) -> {
            count = count + 1
        }
    }
}

actor PongActor {
    state ping_ref = 0
    state pings_received = 0

    receive {
        Ping(seq) -> {
            pings_received = pings_received + 1
            // Reply back to the wired ping actor
            ping_ref ! Pong { seq: seq }
        }
    }
}

actor SimpleReceiver {
    state received = 0

    receive {
        Ping(seq) -> {
            received = received + 1
        }
    }
}

// Actor that receives a ping with sender ref and replies via message field
actor Replier {
    state pings = 0

    receive {
        PingWithRef(sender_ref) -> {
            pings = pings + 1
            if sender_ref != 0 {
                sender_ref ! Pong { seq: pings }
            }
        }
    }
}

// Actor that counts pongs received
actor PongCounter {
    state count = 0

    receive {
        Pong(seq) -> {
            count = count + 1
        }
    }
}

main() {
    print("=== Actor-to-Actor Communication Tests ===\n\n")

    // Test 1: actor-to-actor forwarding with state wiring
    print("Test 1: bidirectional ping-pong\n")
    pong = spawn(PongActor())
    ping = spawn(PingActor())

    // Wire actors to each other via state fields
    ping.pong_ref = pong
    pong.ping_ref = ping

    // Kick off: ping sends 5 pings to pong, pong replies with 5 pongs
    ping ! Go {}

    wait_for_idle()

    if pong.pings_received == 5 {
        print("  PASS: pong received 5 pings\n")
    } else {
        print("  FAIL: pong received ")
        print(pong.pings_received)
        print("\n")
        exit(1)
    }
    if ping.count == 5 {
        print("  PASS: ping received 5 pongs back\n")
    } else {
        print("  FAIL: ping count = ")
        print(ping.count)
        print("\n")
        exit(1)
    }

    // Test 2: send more messages after wait_for_idle (tests scheduler stays alive)
    print("\nTest 2: messages after wait_for_idle\n")
    r1 = spawn(SimpleReceiver())
    r2 = spawn(SimpleReceiver())
    r3 = spawn(SimpleReceiver())

    r1 ! Ping { seq: 1 }
    r2 ! Ping { seq: 1 }
    r2 ! Ping { seq: 2 }
    r3 ! Ping { seq: 1 }
    r3 ! Ping { seq: 2 }
    r3 ! Ping { seq: 3 }

    wait_for_idle()

    if r1.received == 1 {
        print("  PASS: r1 received 1\n")
    } else {
        print("  FAIL: r1 received ")
        print(r1.received)
        print("\n")
        exit(1)
    }
    if r2.received == 2 {
        print("  PASS: r2 received 2\n")
    } else {
        print("  FAIL: r2 received ")
        print(r2.received)
        print("\n")
        exit(1)
    }
    if r3.received == 3 {
        print("  PASS: r3 received 3\n")
    } else {
        print("  FAIL: r3 received ")
        print(r3.received)
        print("\n")
        exit(1)
    }

    // Test 3: third wait phase — reuse existing actors
    print("\nTest 3: third phase with existing actors\n")
    r1 ! Ping { seq: 10 }
    r1 ! Ping { seq: 11 }

    wait_for_idle()

    if r1.received == 3 {
        print("  PASS: r1 total received 3\n")
    } else {
        print("  FAIL: r1 received ")
        print(r1.received)
        print("\n")
        exit(1)
    }

    // Test 4: actor ref passed through message field (not state wiring)
    print("\nTest 4: actor ref in message field\n")
    replier = spawn(Replier())
    counter = spawn(PongCounter())

    // Send pings with the counter's ref embedded in the message
    replier ! PingWithRef { sender_ref: counter }
    replier ! PingWithRef { sender_ref: counter }
    replier ! PingWithRef { sender_ref: counter }

    wait_for_idle()

    if replier.pings == 3 {
        print("  PASS: replier received 3 pings\n")
    } else {
        print("  FAIL: replier pings = ")
        print(replier.pings)
        print("\n")
        exit(1)
    }
    if counter.count == 3 {
        print("  PASS: counter received 3 pongs via message ref\n")
    } else {
        print("  FAIL: counter count = ")
        print(counter.count)
        print("\n")
        exit(1)
    }

    print("\n=== All Actor Communication Tests Passed ===\n")
}
