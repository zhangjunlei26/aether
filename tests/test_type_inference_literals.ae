// Test: Type inference from literals
// Python-style: no 'let' keyword, types inferred automatically

main() {
    // Integer literal
    x = 42;  // Inferred: int
    
    // Float literal
    pi = 3.14;  // Inferred: float
    
    // String literal
    greeting = "Hello";  // Inferred: string
    
    // Boolean
    flag = true;  // Inferred: bool
    
    // Array literal
    nums = [1, 2, 3];  // Inferred: int[]
    
    print(x);
}

