actor Counter {
    state int count = 0;
    
    receive(msg) {
        if (msg.type == 1) {
            count = count + 1;
        }
    }
}

actor Player {
    state int health = 100;
    state int score = 0;
    
    receive(msg) {
        if (msg.type == 10) {
            score = score + msg.payload_int;
        }
    }
}

main() {
    print("Actor tests compiled\n");
}
