actor Counter {
    state int count = 0;
    
    receive(msg) {
        count = count + 1;
    }
}

main() {
    // Correct API: spawn_Counter() and send_Counter() are generated by compiler
    Counter* c = spawn_Counter();
    send_Counter(c, 1, 0);
    Counter_step(c);
    print("Test complete\n");
}
