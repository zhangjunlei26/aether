// Hello Actor - simplest possible actor with message passing

message Greet { id: int }
message Farewell {}

actor Greeter {
    state count = 0;

    receive {
        Greet(id) -> {
            count = count + 1;
            print("Hello! Greeting #");
            print(count);
            print("\n");
        }
        Farewell() -> {
            print("Goodbye!\n");
        }
        _ -> {
            print("Unknown message\n");
        }
    }
}

main() {
    greeter = spawn(Greeter());
    greeter ! Greet { id: 1 };
    greeter ! Greet { id: 2 };
    greeter ! Farewell {};

    // Wait for all messages to be processed
    wait_for_idle();

    print("Total greetings: ");
    print(greeter.count);
    print("\n");
}
