// Runtime Integration Test Program
// Python-style syntax: no 'let', no 'func', types inferred

struct Player {
    name,
    health,
    score
}

calculate_damage(base, defense) {
    return base - defense;
}

actor game_server {
    state players_count = 0
    
    receive(msg) {
        players_count++;
    }
}

main() {
    // Test 1: String operations (type inferred: string)
    greeting = "Hello, World!";
    aether_print_line(greeting);
    
    // Test 2: Type inference in struct
    p = Player{ 
        name: "Alice", 
        health: 100,
        score: 0
    };
    
    // Test 3: Math operations (types inferred: int)
    damage = calculate_damage(50, 10);
    aether_print_int(damage);  // Should print 40
    
    // Test 4: Actor spawning
    server = spawn_game_server();
    send_game_server(server, 1, 0);
    
    // Test 5: Arrays with inference (type: int[])
    nums = [1, 2, 3, 4, 5];
    sum = nums[0] + nums[1];
    aether_print_int(sum);  // Should print 3
}

