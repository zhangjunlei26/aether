// Test: Type-Specific Memory Pools
// Verifies that generated pools provide faster allocation than general pools

message Increment { value: int }
message Decrement { value: int }
message Status { active: bool, count: int }

actor Counter {
    state count: int = 0;
    
    receive {
        Increment { value } => {
            self.count = self.count + value;
        }
        Decrement { value } => {
            self.count = self.count - value;
        }
        Status { active, count } => {
            // Query status
        }
    }
}

fn main() {
    let counter = spawn(Counter());
    
    // Send 1M messages to test pool performance
    let i = 0;
    while (i < 1000000) {
        counter ! Increment { value: 1 };
        i = i + 1;
    }
}
