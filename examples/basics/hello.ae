// Hello World - Your first Aether program
// Run with: ae run examples/basics/hello.ae

main() {
    println("Hello, Aether!");

    // Variables with type inference
    x = 42;
    y = 8;

    if (x > y) {
        println("x is greater than y");
    }

    // Simple arithmetic
    sum = x + y;
    println("Sum: ${sum}");

    println("Welcome to Aether!");
}
