// Supervisor Pattern (simplified)
actor Worker {
    state work_done = 0;
    
    receive(msg) {
        work_done = work_done + 1;
    }
}

actor Supervisor {
    state workers = 0;
    
    receive(msg) {
        workers = workers + 1;
    }
}

main() {
    print("Supervisor pattern example\n");
}
