# Build outputs
/build/*
/target/
*.exe
*.o
*.obj
*.a
*.d
*.so
*.dll
*.dylib
*.log
.claude/
-o
logs

# Generated C code (from .ae compilation)
output.c
generated_*.c
/tmp/ping_pong_aether.c*

# Package lock files
aether.lock
package-lock.json

# Benchmark build artifacts (compiled binaries for each pattern)
benchmarks/cross-language/*/ping_pong
benchmarks/cross-language/*/counting
benchmarks/cross-language/*/thread_ring
benchmarks/cross-language/*/fork_join
benchmarks/cross-language/*/skynet
benchmarks/cross-language/*/skynet_asan
benchmarks/cross-language/*/skynet_noinline
benchmarks/cross-language/*/*.exe
benchmarks/cross-language/*/*.beam
benchmarks/cross-language/*/*.class
benchmarks/cross-language/*/erl_crash.dump
benchmarks/cross-language/**/*.dSYM/

# Zig build artifacts
benchmarks/cross-language/zig/.zig-cache/
benchmarks/cross-language/zig/zig-out/

# Go build artifacts
benchmarks/cross-language/go/go.sum

# Rust build artifacts
benchmarks/cross-language/rust/target/
benchmarks/cross-language/rust/Cargo.lock

# Scala build artifacts
benchmarks/cross-language/scala/target/
benchmarks/cross-language/scala/project/target/
benchmarks/cross-language/scala/project/project/

# Pony build artifacts
benchmarks/cross-language/pony/pony
benchmarks/cross-language/pony/*/ping_pong
benchmarks/cross-language/pony/*/counting
benchmarks/cross-language/pony/*/thread_ring
benchmarks/cross-language/pony/*/fork_join

# Aether codegen intermediates
benchmarks/cross-language/aether/*.c
!benchmarks/cross-language/aether/Makefile

# Zig cache (alternate location)
benchmarks/cross-language/zig/zig-cache/

# Visualization server
benchmarks/cross-language/visualize/server
benchmarks/cross-language/visualize/server.exe
benchmarks/cross-language/visualize/server_generated.c
benchmarks/cross-language/visualize/results_*.json
zig_minimal

# Editor
.vscode/
.cursor/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini
